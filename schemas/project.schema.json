{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Multi-agent project",
  "type": "object",
  "required": [
    "id",
    "name",
    "repository_url",
    "organization",
    "primary_category",
    "tags",
    "project_type",
    "coordination_pattern",
    "description_en",
    "description_zh",
    "self_hosted",
    "status",
    "github",
    "added_at",
    "last_reviewed_at",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "repository_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github.com/"
    },
    "homepage_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "organization": {
      "type": "string"
    },
    "primary_category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "project_type": {
      "enum": [
        "framework",
        "application",
        "product",
        "platform",
        "infrastructure",
        "research",
        "benchmark"
      ]
    },
    "coordination_pattern": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "description_en": {
      "type": "string",
      "minLength": 30,
      "maxLength": 420
    },
    "description_zh": {
      "type": "string",
      "minLength": 15,
      "maxLength": 240
    },
    "primary_language": {
      "type": [
        "string",
        "null"
      ]
    },
    "license": {
      "type": [
        "string",
        "null"
      ]
    },
    "self_hosted": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "active",
        "experimental",
        "inactive",
        "archived"
      ]
    },
    "region": {
      "type": "string"
    },
    "github": {
      "type": "object",
      "required": [
        "archived"
      ],
      "properties": {
        "stars": {
          "type": "integer",
          "minimum": 0
        },
        "forks": {
          "type": "integer",
          "minimum": 0
        },
        "open_issues": {
          "type": "integer",
          "minimum": 0
        },
        "last_push_at": {
          "type": "string",
          "format": "date-time"
        },
        "archived": {
          "type": "boolean"
        }
      }
    },
    "added_at": {
      "type": "string",
      "format": "date"
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "source": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
