{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate",
  "type": "object",
  "required": [
    "full_name",
    "url",
    "source_query"
  ],
  "properties": {
    "full_name": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "source_query": {
      "type": "string"
    },
    "archived": {
      "type": "boolean"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stars": {
      "type": "integer",
      "minimum": 0
    },
    "relevance": {
      "type": "number"
    }
  },
  "additionalProperties": true
}
