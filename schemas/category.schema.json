{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Category",
  "type": "object",
  "required": [
    "id",
    "group",
    "name_en",
    "name_zh",
    "description_en",
    "description_zh",
    "order"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "group": {
      "enum": [
        "Foundations",
        "Applications"
      ]
    },
    "name_en": {
      "type": "string"
    },
    "name_zh": {
      "type": "string"
    },
    "description_en": {
      "type": "string"
    },
    "description_zh": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
