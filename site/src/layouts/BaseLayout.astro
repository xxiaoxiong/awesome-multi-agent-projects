---
import "../styles/global.css";
import { Github, Languages, Moon, Sun } from "lucide-astro";
interface Props {
  title: string;
  description: string;
  lang?: "en" | "zh";
  canonicalPath?: string;
  alternatePath?: string;
}
const { title, description, lang = "en", canonicalPath = Astro.url.pathname, alternatePath } = Astro.props;
const base = "https://deployment-pending.invalid";
const canonical = new URL(canonicalPath, base);
const alternate = alternatePath ? new URL(alternatePath, base) : null;
const zh = lang === "zh";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: canonical.toString(),
  isPartOf: { "@type": "WebSite", name: "Awesome Multi-Agent Projects", url: base }
};
---
<!doctype html>
<html lang={zh ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={zh ? "zh-CN" : "en"} href={canonical} />
    {alternate && <link rel="alternate" hreflang={zh ? "en" : "zh-CN"} href={alternate} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${base}/social-preview.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      const saved = localStorage.getItem("theme");
      if (saved === "dark" || (!saved && matchMedia("(prefers-color-scheme: dark)").matches)) document.documentElement.classList.add("dark");
    </script>
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/85 backdrop-blur dark:border-slate-800 dark:bg-slate-950/85">
      <div class="container-page flex h-16 items-center justify-between gap-4">
        <a href={zh ? "/zh/" : "/"} class="flex items-center gap-3 font-bold">
          <img src="/logo.svg" width="34" height="34" alt="" />
          <span class="hidden sm:inline">Awesome Multi-Agent Projects</span>
          <span class="sm:hidden">AMAP</span>
        </a>
        <nav class="flex items-center gap-1 text-sm" aria-label="Primary navigation">
          <a class="rounded-lg px-3 py-2 hover:bg-slate-100 dark:hover:bg-slate-800" href={zh ? "/zh/projects" : "/projects"}>{zh ? "项目" : "Projects"}</a>
          <a class="hidden rounded-lg px-3 py-2 hover:bg-slate-100 sm:block dark:hover:bg-slate-800" href={zh ? "/zh/updates" : "/updates"}>{zh ? "更新" : "Updates"}</a>
          <a class="hidden rounded-lg px-3 py-2 hover:bg-slate-100 sm:block dark:hover:bg-slate-800" href={zh ? "/zh/about" : "/about"}>{zh ? "关于" : "About"}</a>
          <a class="rounded-lg p-2 hover:bg-slate-100 dark:hover:bg-slate-800" href={zh ? canonicalPath.replace(/^\/zh/, "") || "/" : `/zh${canonicalPath === "/" ? "/" : canonicalPath}`} aria-label={zh ? "English" : "简体中文"}><Languages size={18} /></a>
          <a class="rounded-lg p-2 hover:bg-slate-100 dark:hover:bg-slate-800" href="https://github.com/xxiaoxiong/awesome-multi-agent-projects" aria-label="GitHub"><Github size={18} /></a>
          <button id="theme-toggle" class="rounded-lg p-2 hover:bg-slate-100 dark:hover:bg-slate-800" aria-label={zh ? "切换主题" : "Toggle theme"}><Sun class="hidden dark:block" size={18} /><Moon class="dark:hidden" size={18} /></button>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="mt-20 border-t border-slate-200 py-10 dark:border-slate-800">
      <div class="container-page flex flex-col gap-4 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between">
        <p>Curated with care · Data snapshot 2026-07-20</p>
        <p><a class="hover:text-indigo-600" href="https://github.com/xxiaoxiong/awesome-multi-agent-projects/blob/main/CONTRIBUTING.md">{zh ? "贡献指南" : "Contributing"}</a> · CC0-1.0</p>
      </div>
    </footer>
    <script is:inline>
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
      });
    </script>
  </body>
</html>
