---
import { ExternalLink, Github, Star } from "lucide-astro";
const { project, category, lang = "en" } = Astro.props;
const zh = lang === "zh";
---
<article class="card project-card h-full" data-id={project.id} data-search={`${project.name} ${project.description_en} ${project.description_zh} ${project.tags.join(" ")}`} data-category={project.primary_category} data-group={category.group} data-type={project.project_type} data-tags={project.tags.join(",")} data-language={project.primary_language ?? ""} data-self-hosted={String(project.self_hosted)} data-status={project.status} data-added={project.added_at} data-stars={project.github.stars ?? 0} data-name={project.name.toLowerCase()}>
  <div class="mb-3 flex items-start justify-between gap-3">
    <div>
      <a href={`${zh ? "/zh" : ""}/projects/${project.id}`} class="text-lg font-bold hover:text-indigo-600">{project.name}</a>
      <p class="mt-1 text-xs font-medium uppercase tracking-wide text-indigo-600 dark:text-indigo-400">{zh ? category.name_zh : category.name_en}</p>
    </div>
    <span class="badge">{project.project_type}</span>
  </div>
  <p class="mb-4 text-sm leading-6 text-slate-600 dark:text-slate-300">{zh ? project.description_zh : project.description_en}</p>
  <div class="mb-4 flex flex-wrap gap-1.5">{project.tags.slice(0, 3).map((tag: string) => <span class="badge">{tag}</span>)}</div>
  <div class="flex flex-wrap items-center gap-3 border-t border-slate-100 pt-3 text-xs text-slate-500 dark:border-slate-800">
    {project.primary_language && <span>{project.primary_language}</span>}
    {project.license && <span>{project.license}</span>}
    {project.self_hosted && <span>{zh ? "可自托管" : "Self-hosted"}</span>}
    {project.github.stars !== undefined && <span class="inline-flex items-center gap-1"><Star size={13} />{project.github.stars.toLocaleString()}</span>}
  </div>
  <div class="mt-4 flex items-center justify-between gap-3">
    <a class="inline-flex items-center rounded-lg bg-indigo-50 px-3 py-2 text-xs font-bold text-indigo-700 hover:bg-indigo-100 dark:bg-indigo-950 dark:text-indigo-300 dark:hover:bg-indigo-900" href={`${zh ? "/zh" : ""}/projects/${project.id}`}>{zh ? "查看站内研究" : "View research"}</a>
    <span class="flex gap-3 text-slate-400">
      <a class="hover:text-slate-700 dark:hover:text-slate-200" href={project.repository_url} aria-label={`${project.name} GitHub`}><Github size={16} /></a>
      {project.homepage_url && <a class="hover:text-slate-700 dark:hover:text-slate-200" href={project.homepage_url} aria-label={`${project.name} website`}><ExternalLink size={16} /></a>}
    </span>
  </div>
</article>
