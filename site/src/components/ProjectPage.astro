---
import { ExternalLink, Github, Star } from "lucide-astro";
import data from "../generated/data.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "./ProjectCard.astro";
const { project, lang = "en" } = Astro.props;
const zh = lang === "zh";
const category = data.categories.find((item) => item.id === project.primary_category)!;
const related = data.projects.filter((item) => item.primary_category === project.primary_category && item.id !== project.id).slice(0, 3);
---
<BaseLayout title={`${project.name} — Awesome Multi-Agent Projects`} description={zh ? project.description_zh : project.description_en} lang={lang} canonicalPath={`${zh ? "/zh" : ""}/projects/${project.id}`} alternatePath={`${zh ? "" : "/zh"}/projects/${project.id}`}>
  <article class="container-page py-14">
    <a class="text-sm font-semibold text-indigo-600" href={`${zh ? "/zh" : ""}/categories/${category.id}`}>{zh ? category.name_zh : category.name_en}</a>
    <div class="mt-4 flex flex-col justify-between gap-6 lg:flex-row lg:items-start">
      <div class="max-w-4xl"><h1 class="text-4xl font-black sm:text-5xl">{project.name}</h1><p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">{zh ? project.description_zh : project.description_en}</p></div>
      <div class="flex gap-3"><a class="button-primary gap-2" href={project.repository_url}><Github size={18} />GitHub</a>{project.homepage_url && <a class="button-secondary gap-2" href={project.homepage_url}><ExternalLink size={18} />{zh ? "官网" : "Website"}</a>}</div>
    </div>
    <dl class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="card"><dt class="text-xs uppercase text-slate-500">{zh ? "项目类型" : "Project type"}</dt><dd class="mt-2 font-bold">{project.project_type}</dd></div>
      <div class="card"><dt class="text-xs uppercase text-slate-500">{zh ? "主要语言" : "Language"}</dt><dd class="mt-2 font-bold">{project.primary_language ?? "—"}</dd></div>
      <div class="card"><dt class="text-xs uppercase text-slate-500">{zh ? "许可证" : "License"}</dt><dd class="mt-2 font-bold">{project.license ?? "—"}</dd></div>
      <div class="card"><dt class="text-xs uppercase text-slate-500">{zh ? "自托管" : "Self-hosted"}</dt><dd class="mt-2 font-bold">{project.self_hosted ? (zh ? "支持" : "Yes") : (zh ? "否" : "No")}</dd></div>
    </dl>
    <section class="mt-10 grid gap-8 lg:grid-cols-2">
      <div><h2 class="text-xl font-bold">{zh ? "协作模式" : "Coordination patterns"}</h2><div class="mt-3 flex flex-wrap gap-2">{project.coordination_pattern.map((item: string) => <span class="badge">{item}</span>)}</div></div>
      <div><h2 class="text-xl font-bold">{zh ? "标签" : "Tags"}</h2><div class="mt-3 flex flex-wrap gap-2">{project.tags.map((item: string) => <span class="badge">{item}</span>)}</div></div>
    </section>
    <section class="mt-10 rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
      <h2 class="text-xl font-bold">{zh ? "GitHub 静态快照" : "GitHub snapshot"}</h2>
      <div class="mt-4 flex flex-wrap gap-6 text-sm text-slate-600 dark:text-slate-300"><span class="inline-flex items-center gap-1"><Star size={15} />{project.github.stars ?? (zh ? "待同步" : "Not synced")}</span><span>{zh ? "最后检查" : "Last reviewed"}: {project.last_reviewed_at}</span><span>Status: {project.status}</span></div>
    </section>
    {related.length > 0 && <section class="mt-14"><h2 class="mb-6 text-2xl font-bold">{zh ? "同分类项目" : "Related projects"}</h2><div class="grid gap-5 md:grid-cols-3">{related.map((item) => <ProjectCard project={item} category={category} lang={lang} />)}</div></section>}
  </article>
</BaseLayout>
