---
import {
  Activity,
  ArrowLeft,
  BookOpenCheck,
  CheckCircle2,
  ExternalLink,
  Github,
  Network,
  Scale,
  ShieldCheck,
  Sparkles,
  Star,
  Target,
  TriangleAlert
} from "lucide-astro";
import data from "../generated/data.json";
import { buildProjectProfile } from "../lib/project-profile";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "./ProjectCard.astro";
const { project, lang = "en" } = Astro.props;
const zh = lang === "zh";
const category = data.categories.find((item) => item.id === project.primary_category)!;
const related = data.projects.filter((item) => item.primary_category === project.primary_category && item.id !== project.id).slice(0, 3);
const profile = buildProjectProfile(project, lang);
const statusLabels = {
  active: zh ? "活跃" : "Active",
  experimental: zh ? "实验性" : "Experimental",
  inactive: zh ? "不活跃" : "Inactive",
  archived: zh ? "已归档" : "Archived"
};
const typeLabels = {
  framework: zh ? "框架" : "Framework",
  application: zh ? "应用" : "Application",
  product: zh ? "产品" : "Product",
  platform: zh ? "平台" : "Platform",
  infrastructure: zh ? "基础设施" : "Infrastructure",
  research: zh ? "研究实现" : "Research",
  benchmark: zh ? "评测基准" : "Benchmark"
};
const statusLabel = (value: string) => statusLabels[value as keyof typeof statusLabels] ?? value;
const typeLabel = (value: string) => typeLabels[value as keyof typeof typeLabels] ?? value;
const formatNumber = (value?: number) => value === undefined ? (zh ? "待同步" : "Not synced") : value.toLocaleString();
---
<BaseLayout title={`${project.name} — Awesome Multi-Agent Projects`} description={zh ? project.description_zh : project.description_en} lang={lang} canonicalPath={`${zh ? "/zh" : ""}/projects/${project.id}`} alternatePath={`${zh ? "" : "/zh"}/projects/${project.id}`}>
  <article>
    <header class="border-b border-slate-200 bg-gradient-to-br from-indigo-50 via-white to-cyan-50 dark:border-slate-800 dark:from-indigo-950/40 dark:via-slate-950 dark:to-cyan-950/30">
      <div class="container-page py-10 sm:py-14">
        <a class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-indigo-600 dark:text-slate-300" href={`${zh ? "/zh" : ""}/projects`}>
          <ArrowLeft size={16} />{zh ? "返回项目目录" : "Back to directory"}
        </a>
        <div class="mt-7 flex flex-col justify-between gap-8 lg:flex-row lg:items-start">
          <div class="max-w-4xl">
            <div class="flex flex-wrap items-center gap-2">
              <a class="badge border-indigo-200 bg-indigo-50 text-indigo-700 hover:border-indigo-400 dark:border-indigo-800 dark:bg-indigo-950 dark:text-indigo-300" href={`${zh ? "/zh" : ""}/categories/${category.id}`}>{zh ? category.name_zh : category.name_en}</a>
              <span class="badge">{typeLabel(project.project_type)}</span>
              <span class:list={["badge", project.status === "active" ? "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-300" : "border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-300"]}>{statusLabel(project.status)}</span>
            </div>
            <h1 class="mt-5 text-4xl font-black tracking-tight sm:text-6xl">{project.name}</h1>
            <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-300">{zh ? project.description_zh : project.description_en}</p>
          </div>
          <div class="flex flex-wrap gap-3">
            {project.homepage_url && <a class="button-primary gap-2" href={project.homepage_url} rel="noreferrer"><ExternalLink size={18} />{zh ? "访问官网" : "Official website"}</a>}
            <a class={project.homepage_url ? "button-secondary gap-2" : "button-primary gap-2"} href={project.repository_url} rel="noreferrer"><Github size={18} />GitHub</a>
          </div>
        </div>
      </div>
    </header>

    <div class="container-page grid gap-10 py-10 lg:grid-cols-[minmax(0,1fr)_18rem] lg:py-14">
      <main class="min-w-0">
        <nav aria-label={zh ? "本页目录" : "On this page"} class="mb-10 rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900 lg:hidden">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{zh ? "本页内容" : "On this page"}</p>
          <div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
            <a href="#overview">{zh ? "项目定位" : "Project overview"}</a>
            <a href="#coordination">{zh ? "协作机制" : "Coordination"}</a>
            <a href="#capabilities">{zh ? "能力与场景" : "Capabilities & use cases"}</a>
            <a href="#adoption">{zh ? "采用评估" : "Adoption review"}</a>
            <a href="#evidence">{zh ? "研究依据" : "Research basis"}</a>
          </div>
        </nav>

        <section id="overview" class="scroll-mt-24">
          <div class="section-heading">
            <span class="section-icon"><BookOpenCheck size={20} /></span>
            <div>
              <p class="eyebrow">{zh ? "站内研究档案" : "Editorial research profile"}</p>
              <h2>{zh ? "这个项目解决什么问题？" : "What problem does this project address?"}</h2>
            </div>
          </div>
          <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-8">
            <p class="text-lg leading-8 text-slate-700 dark:text-slate-200">{profile.purpose}</p>
            <p class="mt-5 border-l-4 border-indigo-500 pl-5 leading-7 text-slate-600 dark:text-slate-300">{zh ? project.description_zh : project.description_en}</p>
          </div>
        </section>

        <section id="coordination" class="mt-14 scroll-mt-24">
          <div class="section-heading">
            <span class="section-icon"><Network size={20} /></span>
            <div>
              <p class="eyebrow">{zh ? "多智能体核心" : "Multi-agent core"}</p>
              <h2>{zh ? "智能体如何协作？" : "How do the agents coordinate?"}</h2>
            </div>
          </div>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {profile.coordinationDetails.map((item) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
                <div class="flex items-center gap-3">
                  <span class="grid h-9 w-9 place-items-center rounded-xl bg-indigo-100 font-bold text-indigo-700 dark:bg-indigo-950 dark:text-indigo-300">{item.name.slice(0, 1)}</span>
                  <h3 class="font-bold">{item.name}</h3>
                </div>
                <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">{item.description}</p>
              </div>
            ))}
          </div>
        </section>

        <section id="capabilities" class="mt-14 scroll-mt-24">
          <div class="section-heading">
            <span class="section-icon"><Target size={20} /></span>
            <div>
              <p class="eyebrow">{zh ? "应用判断" : "Application fit"}</p>
              <h2>{zh ? "适合用来做什么？" : "Where can it be useful?"}</h2>
            </div>
          </div>
          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <div class="rounded-3xl border border-emerald-200 bg-emerald-50/70 p-6 dark:border-emerald-900 dark:bg-emerald-950/30">
              <h3 class="flex items-center gap-2 font-bold text-emerald-900 dark:text-emerald-200"><Sparkles size={19} />{zh ? "典型使用场景" : "Representative use cases"}</h3>
              <ul class="mt-5 space-y-4">
                {profile.useCases.map((item) => <li class="flex gap-3 text-sm leading-6 text-emerald-950/80 dark:text-emerald-100/80"><CheckCircle2 class="mt-0.5 shrink-0" size={17} />{item}</li>)}
              </ul>
            </div>
            <div class="rounded-3xl border border-indigo-200 bg-indigo-50/70 p-6 dark:border-indigo-900 dark:bg-indigo-950/30">
              <h3 class="flex items-center gap-2 font-bold text-indigo-900 dark:text-indigo-200"><Scale size={19} />{zh ? "值得关注的特点" : "Why it may be worth examining"}</h3>
              <ul class="mt-5 space-y-4">
                {profile.strengths.map((item) => <li class="flex gap-3 text-sm leading-6 text-indigo-950/80 dark:text-indigo-100/80"><CheckCircle2 class="mt-0.5 shrink-0" size={17} />{item}</li>)}
              </ul>
            </div>
          </div>
        </section>

        <section id="adoption" class="mt-14 scroll-mt-24">
          <div class="section-heading">
            <span class="section-icon"><ShieldCheck size={20} /></span>
            <div>
              <p class="eyebrow">{zh ? "工程采用指南" : "Engineering adoption guide"}</p>
              <h2>{zh ? "采用前应该检查什么？" : "What should you verify before adoption?"}</h2>
            </div>
          </div>
          <div class="mt-6 grid gap-6 xl:grid-cols-2">
            <div class="rounded-3xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
              <h3 class="font-bold">{zh ? "项目层面的注意事项" : "Project-level trade-offs"}</h3>
              <ul class="mt-5 space-y-4">
                {profile.cautions.map((item) => <li class="flex gap-3 text-sm leading-6 text-slate-600 dark:text-slate-300"><TriangleAlert class="mt-0.5 shrink-0 text-amber-500" size={17} />{item}</li>)}
              </ul>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
              <h3 class="font-bold">{zh ? "技术与许可事实" : "Technical and licensing facts"}</h3>
              <ul class="mt-5 space-y-4">
                {profile.adoptionFacts.map((item) => <li class="flex gap-3 text-sm leading-6 text-slate-600 dark:text-slate-300"><CheckCircle2 class="mt-0.5 shrink-0 text-slate-400" size={17} />{item}</li>)}
              </ul>
            </div>
          </div>
          <div class="mt-6 rounded-3xl border border-amber-200 bg-amber-50/70 p-6 dark:border-amber-900 dark:bg-amber-950/30">
            <h3 class="font-bold text-amber-950 dark:text-amber-200">{zh ? "建议的验证清单" : "Recommended evaluation checklist"}</h3>
            <ol class="mt-5 grid gap-4 md:grid-cols-3">
              {profile.evaluation.map((item, index) => (
                <li class="flex gap-3 text-sm leading-6 text-amber-950/80 dark:text-amber-100/80">
                  <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-amber-200 text-xs font-black text-amber-900 dark:bg-amber-900 dark:text-amber-100">{index + 1}</span>
                  {item}
                </li>
              ))}
            </ol>
          </div>
        </section>

        <section id="evidence" class="mt-14 scroll-mt-24">
          <div class="section-heading">
            <span class="section-icon"><Activity size={20} /></span>
            <div>
              <p class="eyebrow">{zh ? "可追溯信息" : "Traceable information"}</p>
              <h2>{zh ? "研究依据与更新时间" : "Research basis and freshness"}</h2>
            </div>
          </div>
          <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900 sm:p-8">
            <div class="grid gap-8 md:grid-cols-2">
              <div>
                <h3 class="font-bold">{zh ? "本页依据" : "Sources used for this profile"}</h3>
                <ul class="mt-4 space-y-3 text-sm text-slate-600 dark:text-slate-300">
                  {profile.researchBasis.map((item) => <li class="flex gap-2"><CheckCircle2 class="mt-0.5 shrink-0 text-indigo-500" size={16} />{item}</li>)}
                </ul>
              </div>
              <dl class="grid grid-cols-2 gap-4 text-sm">
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800"><dt class="text-slate-500">{zh ? "最后审核" : "Last reviewed"}</dt><dd class="mt-2 font-bold">{profile.reviewedAt}</dd></div>
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800"><dt class="text-slate-500">{zh ? "项目状态" : "Status"}</dt><dd class="mt-2 font-bold">{statusLabel(project.status)}</dd></div>
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800"><dt class="text-slate-500">GitHub Stars</dt><dd class="mt-2 inline-flex items-center gap-1 font-bold"><Star size={15} />{formatNumber(project.github.stars)}</dd></div>
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800"><dt class="text-slate-500">{zh ? "归档状态" : "Archived"}</dt><dd class="mt-2 font-bold">{project.github.archived ? (zh ? "是" : "Yes") : (zh ? "否" : "No")}</dd></div>
              </dl>
            </div>
            <p class="mt-6 border-t border-slate-200 pt-5 text-xs leading-5 text-slate-500 dark:border-slate-800">
              {zh ? "说明：本页用于开源项目发现与工程选型，不构成安全、医疗、法律或投资建议。项目能力与维护状态可能在审核后变化，正式采用前请以官方仓库和文档为准。" : "Note: This page supports open-source discovery and engineering evaluation. It is not security, medical, legal, or financial advice. Capabilities and maintenance status may change after review; verify the official repository and documentation before adoption."}
            </p>
          </div>
        </section>

        {related.length > 0 && (
          <section class="mt-16">
            <div class="flex items-end justify-between gap-4">
              <div><p class="eyebrow">{zh ? "继续探索" : "Continue exploring"}</p><h2 class="mt-1 text-2xl font-black">{zh ? "同分类项目" : "Related projects"}</h2></div>
              <a class="text-sm font-semibold text-indigo-600" href={`${zh ? "/zh" : ""}/categories/${category.id}`}>{zh ? "查看全部" : "View all"}</a>
            </div>
            <div class="mt-6 grid gap-5 md:grid-cols-3">{related.map((item) => <ProjectCard project={item} category={category} lang={lang} />)}</div>
          </section>
        )}
      </main>

      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <nav aria-label={zh ? "本页目录" : "On this page"} class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{zh ? "本页内容" : "On this page"}</p>
            <div class="mt-4 flex flex-col gap-3 text-sm">
              <a class="text-slate-600 hover:text-indigo-600 dark:text-slate-300" href="#overview">{zh ? "项目定位" : "Project overview"}</a>
              <a class="text-slate-600 hover:text-indigo-600 dark:text-slate-300" href="#coordination">{zh ? "协作机制" : "Coordination"}</a>
              <a class="text-slate-600 hover:text-indigo-600 dark:text-slate-300" href="#capabilities">{zh ? "能力与场景" : "Capabilities & use cases"}</a>
              <a class="text-slate-600 hover:text-indigo-600 dark:text-slate-300" href="#adoption">{zh ? "采用评估" : "Adoption review"}</a>
              <a class="text-slate-600 hover:text-indigo-600 dark:text-slate-300" href="#evidence">{zh ? "研究依据" : "Research basis"}</a>
            </div>
          </nav>
          <div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{zh ? "项目快照" : "Project snapshot"}</p>
            <dl class="mt-4 space-y-3 text-sm">
              <div class="flex justify-between gap-4"><dt class="text-slate-500">{zh ? "类型" : "Type"}</dt><dd class="text-right font-semibold">{typeLabel(project.project_type)}</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-slate-500">{zh ? "语言" : "Language"}</dt><dd class="text-right font-semibold">{project.primary_language ?? "—"}</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-slate-500">{zh ? "许可证" : "License"}</dt><dd class="text-right font-semibold">{project.license ?? "—"}</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-slate-500">{zh ? "自托管" : "Self-hosted"}</dt><dd class="text-right font-semibold">{project.self_hosted ? (zh ? "支持" : "Yes") : (zh ? "否" : "No")}</dd></div>
            </dl>
            <div class="mt-5 flex flex-wrap gap-2">{project.tags.map((item: string) => <span class="badge">{item}</span>)}</div>
          </div>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
